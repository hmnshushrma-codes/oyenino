---
import BaseLayout from './BaseLayout.astro';
import NavSimple from '../components/NavSimple.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  keywords?: string;
  robots?: string;
  twitterTitle?: string;
  twitterDesc?: string;
  structuredData?: object;
  needsTurnstile?: boolean;
  extraFonts?: string;
  backText?: string;
  backHref?: string;
}

const {
  title,
  description,
  canonical,
  ogImage,
  keywords,
  robots,
  twitterTitle,
  twitterDesc,
  structuredData,
  needsTurnstile = false,
  extraFonts,
  backText,
  backHref
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  keywords={keywords}
  robots={robots}
  twitterTitle={twitterTitle}
  twitterDesc={twitterDesc}
  structuredData={structuredData}
  needsTurnstile={needsTurnstile}
  extraFonts={extraFonts}
>
  <slot name="head" slot="head" />
  <NavSimple backText={backText} backHref={backHref} />
  <slot />
  <Footer />
</BaseLayout>
